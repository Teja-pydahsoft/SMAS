PORT=3001
HOST=0.0.0.0
MONGODB_URI=mongodb://localhost:27017/smas
AI_SERVER_URL=http://localhost:8000
# Required only if Hugging Face Space is Private (read token from HF settings)
HF_TOKEN=
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=uploads
FACE_MATCH_THRESHOLD=0.42
MIN_MATCH_MARGIN=0.05
SEARCH_TOP_K=5
FACE_EMBEDDING_SIZE=512

# Cloudinary (persistent photo storage — required for hosted deployments)
# Get these from cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# System auth
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=superadmin123

# Web push (overstay alerts) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
