# ============================================================
# SMAS AI instance — copy to .env before deploy
# ============================================================

# buffalo_l: best accuracy, ~1–2 GB RAM  → use on a 4 GB instance
# buffalo_s: ~2x faster, ~500 MB RAM     → use on a 2 GB instance
INSIGHTFACE_MODEL=buffalo_l
DET_SIZE=640,640

# Match to the instance's vCPU count
CPU_THREADS=2

# Must match the backend's .env values
FACE_MATCH_THRESHOLD=0.42
MIN_MATCH_MARGIN=0.05
SEARCH_TOP_K=5
