# ============================================================
# Second AI server (another project) — copy to second.env
# Runs on port 8001 with its own isolated face index.
# ============================================================

# buffalo_s recommended here: two buffalo_l containers can exhaust a
# 4 GB instance. Upgrade the instance before switching this to buffalo_l.
INSIGHTFACE_MODEL=buffalo_s
DET_SIZE=320,320

CPU_THREADS=2

# Must match the second project's backend env values
FACE_MATCH_THRESHOLD=0.42
MIN_MATCH_MARGIN=0.05
SEARCH_TOP_K=5
