# ============================================================
# Second AI server (another project) — copy to second.env
# Runs on port 8001 with its own isolated face index.
# ============================================================

# Two buffalo_l containers need ~3 GB combined — fits on a 4 GB instance
# but add swap as a safety net (see deploy/lightsail/README.md). If the
# instance runs out of memory, upgrade it via snapshot to the 8 GB plan.
INSIGHTFACE_MODEL=buffalo_l
DET_SIZE=640,640

CPU_THREADS=2

# Must match the second project's backend env values
FACE_MATCH_THRESHOLD=0.42
MIN_MATCH_MARGIN=0.05
SEARCH_TOP_K=5
