# ============================================================
# SMAS app instance — copy to .env and fill in before deploy
# ============================================================

# The client's domain (A record must point to this instance's static IP).
# Used by Caddy for HTTPS certificates.
DOMAIN=smas.example.com

# CORS allow-list — must match the domain above, with https://
FRONTEND_URL=https://smas.example.com

# AI server instance — use its PRIVATE IP (Lightsail → AI instance →
# Networking tab). Private traffic stays inside AWS and needs no open
# public port on the AI instance.
AI_SERVER_URL=http://172.26.0.0:8000

# ---- Secrets: generate fresh values for every client ----

# Generate: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# First-login super admin (password is bcrypt-hashed on first boot)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me

# Web push (overstay alerts) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Face matching (defaults match the AI server) ----
FACE_MATCH_THRESHOLD=0.42
MIN_MATCH_MARGIN=0.05
SEARCH_TOP_K=5
FACE_EMBEDDING_SIZE=512

# ---- Cloudinary (OPTIONAL) ----
# Leave blank to store photos on the instance disk (persistent on Lightsail,
# included in snapshots). Fill in only if the client wants cloud photo storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
