# ============================================================
# SMAS backend — copy to backend.env and fill in before deploy
# All values here go ONLY to the backend container.
# After editing: docker compose up -d   (recreates the backend)
# ============================================================

# ---- Database ----
# Default: the MongoDB container bundled in this compose file.
# To use MongoDB Atlas (or any external Mongo) instead, replace with e.g.:
#   MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/smas?retryWrites=true&w=majority
MONGODB_URI=mongodb://mongodb:27017/smas

# ---- AI server (separate Lightsail instance) ----
# Use its PRIVATE IP (Lightsail → AI instance → Networking tab). Private
# traffic stays inside AWS — no public port needed on the AI instance.
AI_SERVER_URL=http://172.26.0.0:8000

# ---- CORS ----
# Must match the public URL of the app (same value as DOMAIN in .env,
# with https:// prefix). Comma-separate multiple origins if needed.
FRONTEND_URL=https://smas.example.com

# ---- Secrets: generate fresh values for every client ----

# Generate: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# First-login super admin (password is bcrypt-hashed on first boot)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me

# Web push (overstay alerts) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Face matching (defaults match the AI server) ----
FACE_MATCH_THRESHOLD=0.42
MIN_MATCH_MARGIN=0.05
SEARCH_TOP_K=5
FACE_EMBEDDING_SIZE=512

# ---- Cloudinary (OPTIONAL) ----
# Leave blank to store photos on the instance disk (persistent on Lightsail,
# included in snapshots). Fill in only if the client wants cloud photo storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
